# Supabase 配置（在 Supabase Dashboard > Settings > API 中获取）
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon_public_key

# Supabase 服务端密钥（仅服务端使用，切勿暴露到客户端）
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key

# 数据库连接（在 Supabase Dashboard > Settings > Database 中获取连接字符串）
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# LLM API Keys
DEEPSEEK_API_KEY=sk-xxx  # DeepSeek 控制台获取：https://platform.deepseek.com
QWEN_API_KEY=sk-xxx      # 阿里云通义千问控制台获取：https://dashscope.aliyuncs.com

# 微信开放平台 OAuth（服务端，仅用于微信登录）
WECHAT_APP_ID=wx_xxx     # 微信开放平台 AppID（需在 open.weixin.qq.com 注册网站应用获取）
WECHAT_APP_SECRET=xxx    # 微信开放平台 AppSecret（仅服务端使用，切勿暴露给前端）

# 应用配置
NEXT_PUBLIC_APP_URL=http://localhost:3000  # 生产环境替换为实际域名

# Next.js standalone 模式运行时配置（生产环境必须）
PORT=3000
HOSTNAME=0.0.0.0

# 注意：生产环境变量保存在 ECS 服务器的 .env.production 文件中，不提交 git
# ECS 服务器路径：~/content-repurposer/.env.production
